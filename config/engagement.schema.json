{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EngagementConfig",
  "description": "FHIR server connection config for a DQAR engagement. Place populated files in config/engagements/ (gitignored).",
  "type": "object",
  "required": ["name", "server_type", "base_url"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable engagement identifier, e.g. 'client-aidbox-dev'"
    },
    "server_type": {
      "type": "string",
      "enum": ["aidbox", "hapi"],
      "description": "FHIR server implementation. Determines auth strategy and any API path differences."
    },
    "base_url": {
      "type": "string",
      "format": "uri",
      "description": "Root URL of the FHIR server, no trailing slash. FHIR endpoints are resolved relative to this."
    },
    "client_id": {
      "type": "string",
      "description": "OAuth2 client ID (Aidbox only)"
    },
    "client_secret": {
      "type": "string",
      "description": "OAuth2 client secret (Aidbox only)"
    },
    "basic_user": {
      "type": "string",
      "description": "HTTP Basic auth username (HAPI only, optional)"
    },
    "basic_password": {
      "type": "string",
      "description": "HTTP Basic auth password (HAPI only, optional)"
    }
  },
  "if": { "properties": { "server_type": { "const": "aidbox" } } },
  "then": { "required": ["client_id", "client_secret"] },
  "examples": [
    {
      "name": "client-aidbox-dev",
      "server_type": "aidbox",
      "base_url": "https://<instance>.edge.aidbox.app",
      "client_id": "<client-id>",
      "client_secret": "<client-secret>"
    },
    {
      "name": "client-hapi-r4",
      "server_type": "hapi",
      "base_url": "https://hapi.fhir.org/baseR4"
    },
    {
      "name": "client-hapi-private",
      "server_type": "hapi",
      "base_url": "https://hapi.example.com/fhir",
      "basic_user": "<username>",
      "basic_password": "<password>"
    }
  ]
}
