# Copy to .env and edit per engagement.

# Image tag to run — matches the version printed on the tarball Sonian delivered,
# e.g. dqar-client-kit-0.1.0.tar.gz -> VERSION=0.1.0
VERSION=local

# Local port to expose the web UI on
PORT=8000

# Stage 1c terminology mode: "local" (default, zero outbound calls) or "live"
# (connects to tx.fhir.org for full terminology binding validation, ~20% slower).
TX_MODE=local
